{
  "buildCommand": "npm run build",
  "outputDirectory": "langoai/dist",
  "framework": "vite",
  "installCommand": "cd langoai && npm install",
  "rootDirectory": "langoai",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/*.js": {
      "memory": 512,
      "maxDuration": 30
    }
  }
}